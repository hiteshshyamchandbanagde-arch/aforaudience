generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ARTIST
  ORGANISER
  VENUE_OWNER
  AUDIENCE
  ADMIN
}

enum EventType {
  OPEN_MIC
  STAND_UP
  POETRY
  THEATER
  LINEUP
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- §4.5 Venue & Event Economics Model additions (additive only - no
// existing fields removed or renamed, so nothing currently live breaks) ---

enum RateType {
  HOURLY
  DAILY
  FLEXIBLE
}

enum CompensationType {
  PAID
  FREE
  BUY_IN
}

enum ApprovalMode {
  MANUAL
  AUTO
}

enum VenueBookingRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OfferProposedBy {
  ORGANISER
  VENUE_OWNER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// Optional per-day override on top of Venue.hourlyRate/dailyRate - a row
// here only exists for days the owner explicitly priced differently (e.g.
// a weekend premium). A day with no row here just uses the venue's base
// rate. Doesn't apply to FLEXIBLE-rate venues, since those are negotiated
// per request anyway via VenueBookingRequest/VenueBookingOffer.
model VenueDayRate {
  id         String    @id @default(cuid())
  venueId    String
  venue      Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  dayOfWeek  DayOfWeek
  hourlyRate Float?
  dailyRate  Float?

  @@unique([venueId, dayOfWeek])
}


model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  password    String
  role        Role     @default(AUDIENCE)
  avatar      String?
  isVerified  Boolean  @default(false)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // B6 — rate limiting / account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // B5 — bumped on every successful password reset so existing JWT
  // sessions (which carry the tokenVersion at time of issue) stop
  // validating in the NextAuth session callback.
  tokenVersion Int @default(0)

  artist              Artist?
  organiser           Organiser?
  venueOwner          VenueOwner?
  bookings            Booking[]
  reviews             Review[]
  passwordResetTokens PasswordResetToken[]
  follows             Follow[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Artist {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  bio          String?
  genre        String[]
  styleTag     String[]
  videoReel    String[]
  socialLinks  Json?
  hypScore     Float    @default(0)
  createdAt    DateTime @default(now())

  applications  Application[]
  performances  Performance[]
  followers     Follow[]
}

// Follows an Artist. userId is the follower (any role can follow, though
// realistically Audience) - artistId is the Artist being followed, not a
// User id, since following is specifically an Artist-facing feature.
model Follow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
}

model Organiser {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  orgName     String
  bio         String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  events        Event[]
  venueBookings VenueBooking[]
  bookingRequests VenueBookingRequest[]
}

model VenueOwner {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  venues      Venue[]
}

model Venue {
  id            String   @id @default(cuid())
  ownerId       String
  owner         VenueOwner @relation(fields: [ownerId], references: [id])
  name          String
  address       String
  city          String
  lat           Float?
  lng           Float?
  capacity      Int
  photos        String[]
  facilities    String[]
  acousticRating Float?
  seatMap       Json?
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())

  // §4.5 - rental rate type. Nullable/optional so existing venues aren't
  // forced into a value; treat missing rateType as "not yet configured"
  // in the UI rather than defaulting silently to one option.
  rateType         RateType?
  hourlyRate       Float?
  dailyRate        Float?
  minDurationHours Int?

  availability  VenueAvailability[]
  bookings      VenueBooking[]
  events        Event[]
  bookingRequests VenueBookingRequest[]
  dayRates      VenueDayRate[]
}

model TicketTier {
  id          String @id @default(cuid())
  eventId     String
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sectionName String
  price       Float
  totalSeats  Int
}

model VenueBookingRequest {
  id             String                    @id @default(cuid())
  organiserId    String
  organiser      Organiser                 @relation(fields: [organiserId], references: [id])
  venueId        String
  venue          Venue                     @relation(fields: [venueId], references: [id])
  eventId        String?
  event          Event?                    @relation(fields: [eventId], references: [id])
  requestedDate  DateTime
  durationHours  Int
  status         VenueBookingRequestStatus @default(PENDING)
  createdAt      DateTime                  @default(now())

  offers VenueBookingOffer[]
}

model VenueBookingOffer {
  id          String               @id @default(cuid())
  requestId   String
  request     VenueBookingRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  proposedBy  OfferProposedBy
  amount      Float
  createdAt   DateTime             @default(now())
}

// Singleton settings row (Admin-managed later, defaults for now) rather
// than hardcoding the flat venue-booking fee or commission rates inline.
model PlatformSettings {
  id                           String @id @default(cuid())
  flatVenueBookingFee          Float  @default(0)
  ticketCommissionRate         Float  @default(0.08)
  performerSlotCommissionRate  Float  @default(0.08)
}


model VenueAvailability {
  id          String   @id @default(cuid())
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])
  date        DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model VenueBooking {
  id           String        @id @default(cuid())
  venueId      String
  venue        Venue         @relation(fields: [venueId], references: [id])
  organiserId  String
  organiser    Organiser     @relation(fields: [organiserId], references: [id])
  eventId      String?
  fromDate     DateTime
  toDate       DateTime
  status       BookingStatus @default(PENDING)
  amount       Float
  createdAt    DateTime      @default(now())

  // §4.5 - snapshotted at confirmation time so later changes to the
  // Venue's published rates don't retroactively alter a confirmed booking.
  agreedRateType    RateType?
  durationHours     Int?
  durationDays      Int?
  platformFeeAmount Float?
}

model Event {
  id             String      @id @default(cuid())
  organiserId    String
  organiser      Organiser   @relation(fields: [organiserId], references: [id])
  venueId        String?
  venue          Venue?      @relation(fields: [venueId], references: [id])
  title          String
  description    String
  type           EventType
  status         EventStatus @default(DRAFT)
  date           DateTime
  startTime      String
  endTime        String
  isFree         Boolean     @default(false)
  ticketPrice    Float?
  totalSeats     Int
  availableSeats Int
  food           Json?
  dresscode      String?
  vibe           String?
  surpriseAct    Boolean     @default(false)
  posterImage    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // §4.5 - ticketPrice above stays for backward compat with existing
  // Organiser dashboard pages until they're migrated to per-section
  // pricing via ticketTiers. New events should prefer ticketTiers.
  maxPerformers        Int?
  applicationApprovalMode ApprovalMode @default(MANUAL)
  maxSeatsPerBooking   Int          @default(4)

  lineup        Performance[]
  applications  Application[]
  bookings      Booking[]
  reviews       Review[]
  ticketTiers   TicketTier[]
  bookingRequests VenueBookingRequest[]
}

model Application {
  id        String            @id @default(cuid())
  eventId   String
  event     Event             @relation(fields: [eventId], references: [id])
  artistId  String
  artist    Artist            @relation(fields: [artistId], references: [id])
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
}

model Performance {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id])
  slot      Int
  duration  Int
  createdAt DateTime @default(now())

  // §4.5 - defaults to FREE (the existing open-mic/exposure norm) so
  // every current Performance row is valid without a data backfill.
  compensationType CompensationType @default(FREE)
  feeAmount        Float?
  buyInAmount      Float?

  reviews   Review[]
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id])
  seats       Json
  totalAmount Float
  status      BookingStatus @default(PENDING)
  paymentId   String?
  ticketCode  String?       @unique
  createdAt   DateTime      @default(now())
}

model Review {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id])
  performanceId String?
  performance   Performance? @relation(fields: [performanceId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime     @default(now())
}