generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ARTIST
  ORGANISER
  VENUE_OWNER
  AUDIENCE
  ADMIN
}

enum EventType {
  OPEN_MIC
  STAND_UP
  POETRY
  THEATER
  LINEUP
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- §4.5 Venue & Event Economics Model additions (additive only - no
// existing fields removed or renamed, so nothing currently live breaks) ---

enum RateType {
  HOURLY
  DAILY
  FLEXIBLE
}

enum CompensationType {
  PAID
  FREE
  BUY_IN
}

enum ApprovalMode {
  MANUAL
  AUTO
}

enum VenueBookingRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OfferProposedBy {
  ORGANISER
  VENUE_OWNER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// Checkpoint 2 — Razorpay payment lifecycle.
// See prisma/migrations/20260713000000_checkpoint_2_payments/migration.sql
// for the reasoning behind each state.
enum PaymentStatus {
  CREATED            // Razorpay order created; user hasn't paid yet
  VERIFIED           // Frontend signature verified; booking marked CONFIRMED
  WEBHOOK_CONFIRMED  // Webhook also confirmed; safety net check passed
  FAILED             // Payment failed at Razorpay
  MISMATCH           // Frontend + webhook disagree; needs human review
}

// Optional per-day override on top of Venue.hourlyRate/dailyRate - a row
// here only exists for days the owner explicitly priced differently (e.g.
// a weekend premium). A day with no row here just uses the venue's base
// rate. Doesn't apply to FLEXIBLE-rate venues, since those are negotiated
// per request anyway via VenueBookingRequest/VenueBookingOffer.
model VenueDayRate {
  id         String    @id @default(cuid())
  venueId    String
  venue      Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  dayOfWeek  DayOfWeek
  hourlyRate Float?
  dailyRate  Float?

  @@unique([venueId, dayOfWeek])
}


model User {
  id          String   @id @default(cuid())
  name        String   @unique // also doubles as the login "username"
  // Optional human-readable display name. `name` is the login username
  // (3-20 chars, [a-zA-Z0-9_]) — historically we also displayed `name`
  // to the user, which meant tickets/emails showed a squished-together
  // lowercase string. `displayName` is where the register form's
  // "Full Name" now lands, and every user-facing surface reads
  // `displayName ?? name`. Existing users have null and can set theirs
  // from Profile.
  displayName String?
  email       String   @unique
  phone       String?
  password    String
  role        Role     @default(AUDIENCE)
  avatar      String?
  isVerified  Boolean  @default(false)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // H3 — moderation. suspendedByUserId is a plain scalar (not a relation),
  // same pattern as Booking.checkedInByUserId - who did it matters for the
  // admin's own record, doesn't need a join for anything the app does.
  // Suspension blocks login (auth.ts) and invalidates any live session
  // immediately (session callback, same mechanism as the B5 password-reset
  // check) rather than waiting out the JWT's 7-day life. Deliberately does
  // NOT cascade-cancel existing confirmed bookings or events already sold -
  // an audience member who already paid for a ticket to a since-suspended
  // Organiser's event isn't part of the reason for the suspension and
  // shouldn't be stranded. It DOES hide that Organiser/Venue Owner's
  // future events/venues from public listings (see events & venues GET
  // routes) so no new tickets get sold while under suspension. Reversible:
  // unsuspend just clears these fields, no separate "banned" state.
  isSuspended       Boolean   @default(false)
  suspendedAt       DateTime?
  suspendReason     String?
  suspendedByUserId String?

  // Universal login code, format AFA<YYMM><6-digit seq>. Generated by a DB
  // trigger on insert (see migration) — every user gets one regardless of
  // role, so "log in with code" works for Audience too, not just
  // Artist/Organiser/Venue Owner (which additionally get their own
  // role-specific code below).
  code String? @unique

  // B6 — rate limiting / account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // B5 — bumped on every successful password reset so existing JWT
  // sessions (which carry the tokenVersion at time of issue) stop
  // validating in the NextAuth session callback.
  tokenVersion Int @default(0)

  artist                Artist?
  organiser              Organiser?
  venueOwner             VenueOwner?
  bookings               Booking[]
  reviews                Review[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  follows                Follow[]
  feedback               Feedback[]
  pushSubscriptions      PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Support widget: one table serves two entry points — the manual
// "Report a bug / suggest a feature" form, and the support chatbot's
// "I don't know that — want to send it to the team?" fallback.
// `fromChatbot` distinguishes them without needing two tables.
//
// `userId` is nullable — guests can submit feedback too (browse-first
// model, no reason to gate this behind login; see design doc §2).
//
// No admin UI to review these yet — that's a follow-up story. For now,
// query via Supabase MCP or curl the table directly. Kept deliberately
// minimal: this model's only job is to reliably capture the message.
model Feedback {
  id          String           @id @default(cuid())
  category    FeedbackCategory
  message     String
  pageUrl     String?
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  fromChatbot Boolean          @default(false)
  status      String           @default("NEW")
  // Optional screenshot, stored as a base64 data URL directly on the
  // row. Client resizes/recompresses to fit well under ~1MB before
  // encoding (see SupportWidget.tsx) so this stays cheap on Postgres.
  // NOT a scalable pattern past low volume — if attachments become
  // heavily used, migrate to Vercel Blob (or S3) and store a URL here
  // instead of the data itself. Fine for an MVP feedback widget.
  attachmentData String?
  createdAt   DateTime         @default(now())

  @@index([status, createdAt])
}

enum FeedbackCategory {
  BUG
  FEATURE_IDEA
  QUESTION
  GENERAL
  OTHER
}

// Mirrors PasswordResetToken's shape. Email verification is deliberately
// non-blocking (see register/route.ts) — this just tracks whether the link
// has been clicked, it never gates login.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Phone OTP, used for both signup verification and OTP-based login.
model Otp {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  purpose    String // "LOGIN" | "SIGNUP_VERIFY"
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

// Backing counter for User/Artist/Organiser/VenueOwner.code generation.
// One row per (prefix, yearMonth); incremented atomically by the
// generate_role_code() DB function so concurrent signups can't collide.
model CodeCounter {
  prefix     String
  yearMonth  String
  currentSeq Int    @default(0)

  @@id([prefix, yearMonth])
}

model Artist {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  bio          String?
  genre        String[]
  styleTag     String[]
  videoReel    String[]
  socialLinks  Json?
  hypScore     Float    @default(0)
  createdAt    DateTime @default(now())

  // Generated by DB trigger on insert, format ART<YYMM><6-digit seq>.
  code String? @unique

  applications  Application[]
  performances  Performance[]
  followers     Follow[]
}

// Follows an Artist. userId is the follower (any role can follow, though
// realistically Audience) - artistId is the Artist being followed, not a
// User id, since following is specifically an Artist-facing feature.
model Follow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
}

model Organiser {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  orgName     String
  bio         String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Generated by DB trigger on insert, format ORG<YYMM><6-digit seq>.
  code String? @unique

  events        Event[]
  venueBookings VenueBooking[]
  bookingRequests VenueBookingRequest[]
}

model VenueOwner {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Generated by DB trigger on insert, format VEN<YYMM><6-digit seq>.
  code String? @unique

  venues      Venue[]
}

model Venue {
  id            String   @id @default(cuid())
  ownerId       String
  owner         VenueOwner @relation(fields: [ownerId], references: [id])
  name          String
  address       String
  city          String
  lat           Float?
  lng           Float?
  mapsUrl       String?
  capacity      Int
  photos        String[]
  facilities    String[]
  acousticRating Float?
  seatMap       Json?
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())

  // §4.5 - rental rate type. Nullable/optional so existing venues aren't
  // forced into a value; treat missing rateType as "not yet configured"
  // in the UI rather than defaulting silently to one option.
  rateType         RateType?
  hourlyRate       Float?
  dailyRate        Float?
  minDurationHours Int?

  availability  VenueAvailability[]
  bookings      VenueBooking[]
  events        Event[]
  bookingRequests VenueBookingRequest[]
  dayRates      VenueDayRate[]
}

model TicketTier {
  id          String @id @default(cuid())
  eventId     String
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sectionName String
  price       Float
  totalSeats  Int
}

model VenueBookingRequest {
  id             String                    @id @default(cuid())
  organiserId    String
  organiser      Organiser                 @relation(fields: [organiserId], references: [id])
  venueId        String
  venue          Venue                     @relation(fields: [venueId], references: [id])
  eventId        String?
  event          Event?                    @relation(fields: [eventId], references: [id])
  requestedDate  DateTime
  durationHours  Int
  status         VenueBookingRequestStatus @default(PENDING)
  createdAt      DateTime                  @default(now())

  offers VenueBookingOffer[]
}

model VenueBookingOffer {
  id          String               @id @default(cuid())
  requestId   String
  request     VenueBookingRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  proposedBy  OfferProposedBy
  amount      Float
  createdAt   DateTime             @default(now())
}

// Singleton config row. The DEAD columns (flatVenueBookingFee,
// ticketCommissionRate, performerSlotCommissionRate) are from a
// pre-fifth-amendment design and are never read by application code;
// they're kept only to match the actual DB shape. See master design
// doc §4.5 / §9.5 for why they're retired.
//
// audienceBookingFee is the live field (Checkpoint 4). Stored in
// PAISE (integer) for consistency with Payment.amount. UI converts
// to/from rupees on display + save. Value of 0 means "no fee".
model PlatformSettings {
  id                           String   @id @default("singleton")
  audienceBookingFee           Int      @default(0)
  // Support chatbot per-session message cap. Enforced client-side via
  // sessionStorage (see SupportWidget.tsx) — not hardened against a
  // determined user clearing storage, but that's a deliberate trade-off:
  // the goal is cost/abuse control against ordinary usage patterns, not
  // security. A server-side counter would need a session/identity model
  // this guest-accessible feature doesn't otherwise need. Configurable
  // so Hitesh can raise/lower it from /dashboard/admin/settings without
  // a deploy. 0 or negative disables chat entirely as an emergency killswitch.
  chatMaxMessagesPerSession    Int      @default(15)
  /// @deprecated dead per fifth amendment — do not read
  flatVenueBookingFee          Float    @default(0)
  /// @deprecated dead per fifth amendment — do not read
  ticketCommissionRate         Float    @default(0.08)
  /// @deprecated dead per fifth amendment — do not read
  performerSlotCommissionRate  Float    @default(0.08)
  updatedAt                    DateTime @updatedAt
}


model VenueAvailability {
  id          String   @id @default(cuid())
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])
  date        DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model VenueBooking {
  id           String        @id @default(cuid())
  venueId      String
  venue        Venue         @relation(fields: [venueId], references: [id])
  organiserId  String
  organiser    Organiser     @relation(fields: [organiserId], references: [id])
  eventId      String?
  fromDate     DateTime
  toDate       DateTime
  status       BookingStatus @default(PENDING)
  amount       Float
  createdAt    DateTime      @default(now())

  // §4.5 - snapshotted at confirmation time so later changes to the
  // Venue's published rates don't retroactively alter a confirmed booking.
  // F6: snapshotHourlyRate / snapshotDailyRate added to fully close the
  // rate-drift gap; the pre-existing four fields captured the deal shape
  // (duration, type, platform fee) but not the actual rate applied.
  agreedRateType     RateType?
  durationHours      Int?
  durationDays       Int?
  platformFeeAmount  Float?
  snapshotHourlyRate Float?
  snapshotDailyRate  Float?
}

model Event {
  id             String      @id @default(cuid())
  organiserId    String
  organiser      Organiser   @relation(fields: [organiserId], references: [id])
  venueId        String?
  venue          Venue?      @relation(fields: [venueId], references: [id])
  title          String
  description    String
  type           EventType
  status         EventStatus @default(DRAFT)
  date           DateTime
  startTime      String
  endTime        String
  isFree         Boolean     @default(false)
  ticketPrice    Float?
  totalSeats     Int
  availableSeats Int
  food           Json?
  dresscode      String?
  vibe           String?
  surpriseAct    Boolean     @default(false)
  posterImage    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // §4.5 - ticketPrice above stays for backward compat with existing
  // Organiser dashboard pages until they're migrated to per-section
  // pricing via ticketTiers. New events should prefer ticketTiers.
  maxPerformers        Int?
  applicationApprovalMode ApprovalMode @default(MANUAL)
  maxSeatsPerBooking   Int          @default(4)

  lineup        Performance[]
  applications  Application[]
  bookings      Booking[]
  reviews       Review[]
  ticketTiers   TicketTier[]
  bookingRequests VenueBookingRequest[]
}

model Application {
  id        String            @id @default(cuid())
  eventId   String
  event     Event             @relation(fields: [eventId], references: [id])
  artistId  String
  artist    Artist            @relation(fields: [artistId], references: [id])
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
}

model Performance {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id])
  slot      Int
  duration  Int
  createdAt DateTime @default(now())

  // §4.5 - defaults to FREE (the existing open-mic/exposure norm) so
  // every current Performance row is valid without a data backfill.
  compensationType CompensationType @default(FREE)
  feeAmount        Float?
  buyInAmount      Float?

  reviews   Review[]
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id])
  seats       Json
  totalAmount Float
  // Checkpoint 4 — audience booking fee split.
  // subtotalAmount    = ticket revenue that goes to the Organiser
  // bookingFeeAmount  = platform's cut (audience-side booking fee)
  // totalAmount       = grand total the audience pays (subtotal + fee)
  // Backfilled on migration: existing rows get subtotal = totalAmount,
  // bookingFeeAmount = 0. Free events stay 0/0/0 forever — per About
  // page, the platform doesn't tax free events.
  subtotalAmount   Float @default(0)
  bookingFeeAmount Float @default(0)
  status      BookingStatus @default(PENDING)
  // Checkpoint 2 — deprecated in favor of the Payment model (below). Kept
  // in the schema for migration safety; nothing in the new payment flow
  // reads or writes it. Remove in a later cleanup once we're sure no old
  // code references it.
  paymentId   String?
  ticketCode  String?       @unique
  createdAt   DateTime      @default(now())

  // Checkpoint 2 — 15-minute TTL on PENDING bookings, so an abandoned
  // checkout doesn't permanently eat capacity. Set at creation time to
  // NOW + 15min; cleared when the booking transitions to CONFIRMED.
  // Capacity checks filter out PENDING rows where expiresAt < NOW().
  expiresAt   DateTime?

  // Ticket delivery tracking. Lives on Booking (not Payment) so free
  // events — which have no Payment row — can be tracked by the same
  // single-flight claim. Backfilled from Payment on migration; new rows
  // set this at delivery time via `updateMany WHERE deliveredAt IS NULL`.
  // See Master Design Doc §9.2 / EPIC M for the bug this fixes.
  deliveredAt   DateTime?
  deliveryError String?

  // Check-in/scan flow (EPIC N). Set once, at the door, by whoever scans
  // the QR (or enters the code manually) - Organiser of the event or an
  // Admin. checkedInByUserId is a plain scalar (not a relation) since it
  // just needs to be a display-only "who scanned this" audit trail, not
  // something queried from the User side.
  checkedInAt       DateTime?
  checkedInByUserId String?

  payment     Payment?

  @@index([status, expiresAt])
}

// Checkpoint 2 — one Payment per Booking. Kept as a separate table (not
// fields on Booking) so future flows (tips, subscriptions, refunds) can
// attach payments without conflating them with tickets.
//
// `amount` is stored in PAISE (integer), never rupees (float). Razorpay
// itself uses paise, and floats accumulate rounding errors on totals.
model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  verifiedAt        DateTime?
  webhookReceivedAt DateTime?
  failureReason     String?

  // Checkpoint 3 — ticket delivery tracking.
  // @deprecated — source of truth moved to Booking.deliveredAt /
  // Booking.deliveryError in the 20260714 migration so free events
  // (which have no Payment row) can be tracked by the same claim.
  // Kept nullable for historical rows' audit trail. Do NOT read or
  // write from application code. Safe to drop in a future cleanup.
  deliveredAt       DateTime?
  deliveryError     String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([razorpayOrderId])
}

model Review {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id])
  performanceId String?
  performance   Performance? @relation(fields: [performanceId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime     @default(now())
}

