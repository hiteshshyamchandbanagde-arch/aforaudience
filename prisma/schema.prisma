generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ARTIST
  ORGANISER
  VENUE_OWNER
  AUDIENCE
  ADMIN
}

enum EventType {
  OPEN_MIC
  STAND_UP
  POETRY
  THEATER
  LINEUP
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  password    String
  role        Role
  avatar      String?
  isVerified  Boolean  @default(false)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artist      Artist?
  organiser   Organiser?
  venueOwner  VenueOwner?
  bookings    Booking[]
  reviews     Review[]
}

model Artist {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  bio          String?
  genre        String[]
  styleTag     String[]
  videoReel    String[]
  socialLinks  Json?
  hypScore     Float    @default(0)
  createdAt    DateTime @default(now())

  applications  Application[]
  performances  Performance[]
}

model Organiser {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  orgName     String
  bio         String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  events        Event[]
  venueBookings VenueBooking[]
}

model VenueOwner {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  venues      Venue[]
}

model Venue {
  id            String   @id @default(cuid())
  ownerId       String
  owner         VenueOwner @relation(fields: [ownerId], references: [id])
  name          String
  address       String
  city          String
  lat           Float?
  lng           Float?
  capacity      Int
  photos        String[]
  facilities    String[]
  acousticRating Float?
  seatMap       Json?
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())

  availability  VenueAvailability[]
  bookings      VenueBooking[]
  events        Event[]
}

model VenueAvailability {
  id          String   @id @default(cuid())
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])
  date        DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model VenueBooking {
  id           String        @id @default(cuid())
  venueId      String
  venue        Venue         @relation(fields: [venueId], references: [id])
  organiserId  String
  organiser    Organiser     @relation(fields: [organiserId], references: [id])
  eventId      String?
  fromDate     DateTime
  toDate       DateTime
  status       BookingStatus @default(PENDING)
  amount       Float
  createdAt    DateTime      @default(now())
}

model Event {
  id             String      @id @default(cuid())
  organiserId    String
  organiser      Organiser   @relation(fields: [organiserId], references: [id])
  venueId        String?
  venue          Venue?      @relation(fields: [venueId], references: [id])
  title          String
  description    String
  type           EventType
  status         EventStatus @default(DRAFT)
  date           DateTime
  startTime      String
  endTime        String
  isFree         Boolean     @default(false)
  ticketPrice    Float?
  totalSeats     Int
  availableSeats Int
  food           Json?
  dresscode      String?
  vibe           String?
  surpriseAct    Boolean     @default(false)
  posterImage    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  lineup        Performance[]
  applications  Application[]
  bookings      Booking[]
  reviews       Review[]
}

model Application {
  id        String            @id @default(cuid())
  eventId   String
  event     Event             @relation(fields: [eventId], references: [id])
  artistId  String
  artist    Artist            @relation(fields: [artistId], references: [id])
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
}

model Performance {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id])
  slot      Int
  duration  Int
  createdAt DateTime @default(now())

  reviews   Review[]
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id])
  seats       Json
  totalAmount Float
  status      BookingStatus @default(PENDING)
  paymentId   String?
  ticketCode  String?       @unique
  createdAt   DateTime      @default(now())
}

model Review {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id])
  performanceId String?
  performance   Performance? @relation(fields: [performanceId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime     @default(now())
}